# Copy to .env and set values. See devsecops.env.schema for full spec.
# No secrets in repo.

POSTGRES_USER=qminiwasm
POSTGRES_PASSWORD=
POSTGRES_DB=qminiwasm_db
RABBITMQ_DEFAULT_USER=qminiwasm
RABBITMQ_DEFAULT_PASS=
SOLACE_ADMIN_PASSWORD=
SOLACE_PASSWORD=
SOLACE_USERNAME=admin
SOLACE_VPN=default
SOLACE_BROKER_WS_URL=ws://solace-pubsub:8008
ZAMMAD_POSTGRES_PASSWORD=
# Gitea server data (repos, DB, config). Use C:\GiTeaRepos so all repos live there.
GITEA_DATA_PATH=C:/GiTeaRepos
GITEA_API_TOKEN=
ZAMMAD_API_TOKEN=
KEYCLOAK_DB_PASSWORD=
# Bootstrap only (first Keycloak init). After that use LDAP for admin and automation client for scripts (docs/IAM_LDAP_AND_AUTOMATION.md).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=
# Automation: service-account client (preferred over admin password). Store secret in Vault.
KEYCLOAK_AUTOMATION_CLIENT_ID=devsecops-automation
KEYCLOAK_AUTOMATION_CLIENT_SECRET=
# Phase 2 IAM: OIDC clients — set after running scripts/configure-keycloak-oidc-clients.ps1; store secrets in Vault
GATEWAY_DOMAIN=localhost
GATEWAY_BASE_URL=http://localhost
KEYCLOAK_PUBLIC_URL=http://localhost/keycloak
KEYCLOAK_REALM=master
GITEA_OIDC_CLIENT_ID=gitea
GITEA_OIDC_CLIENT_SECRET=
N8N_EDITOR_BASE_URL=http://localhost/n8n
N8N_OIDC_CLIENT_ID=n8n
N8N_OIDC_CLIENT_SECRET=
ZAMMAD_PUBLIC_URL=http://localhost/zammad
NIFI_JVM_HEAP_INIT=2g
NIFI_JVM_HEAP_MAX=4g
LLM_SERVICE_ENDPOINT=
LLM_SERVICE_API_KEY=
TELEPORT_JIT_REQUEST_URL=https://teleport/api/v1/jit/request

# Bitwarden (Vaultwarden) — human password manager. Inject BITWARDEN_ADMIN_TOKEN from Vault if set.
BITWARDEN_DOMAIN=http://localhost:8484
BITWARDEN_PORT=8484
BITWARDEN_ADMIN_TOKEN=
BITWARDEN_SIGNUPS_ALLOWED=true
BITWARDEN_INVITATIONS_ALLOWED=true
