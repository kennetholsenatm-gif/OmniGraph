{
  "name": "NetBox → Termius sync (scheduled)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 24
            }
          ]
        }
      },
      "id": "schedule-sync",
      "name": "Every 24 hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "command": "python3 /opt/devsecops-pipeline/scripts/sync_netbox_to_termius.py --format termius-json -o /tmp/termius-hosts.json"
      },
      "id": "exec-sync",
      "name": "Run sync_netbox_to_termius.py",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [280, 0],
      "notesInFlow": true,
      "notes": "Requires n8n host (or sidecar) with Python 3, repo checkout, and env NETBOX_URL + NETBOX_API_TOKEN (from Vault). Adjust DEVSECOPS_PIPELINE_ROOT. For Docker n8n without Python, replace this node with an HTTP call to a small sync service."
    }
  ],
  "connections": {
    "Every 24 hours": {
      "main": [[{ "node": "Run sync_netbox_to_termius.py", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v2"
  },
  "meta": {
    "description": "Optional schedule for NetBox→Termius export; see docs/NETBOX_TERMIUS_SYNC.md"
  }
}
