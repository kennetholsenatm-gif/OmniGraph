# Local deployment target selector
DEVSECOPS_DEPLOYMENT_TARGET=local-lxc

# Runtime model:
# - local-lxc is canonical
# - Docker remains nested inside LXC where workloads require compose
DEVSECOPS_RUNTIME_MODEL=lxc-first

# Optional stack toggles (same behavior as existing launch flow)
DEVSECOPS_INCLUDE_LLM=1
DEVSECOPS_INCLUDE_DISCOVERY=0
DEVSECOPS_INCLUDE_AI_ORCHESTRATION=0
DEVSECOPS_INCLUDE_IDENTITY=0
DEVSECOPS_INCLUDE_SIEM=0
DEVSECOPS_INCLUDE_SDN_TELEMETRY=0
