# User systemd unit — install to ~/.config/systemd/user/code-server.service
# then: systemctl --user daemon-reload && systemctl --user enable --now code-server
#
# Adjust paths and ports. Prefer SSH -L over exposing 0.0.0.0.

[Unit]
Description=code-server (VS Code web) for Hermes/BitNet workspace
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HERMES_BITNET_SRC_ROOT=%h/src
ExecStart=%h/.local/bin/code-server --bind-addr 127.0.0.1:8443 %h/src
Restart=on-failure
RestartSec=5
MemoryMax=2G

[Install]
WantedBy=default.target
