# Optional: connection token + wider bind (e.g. 0.0.0.0). Browser must use:
#   http://HOST:PORT/?tkn=CONTENTS_OF_openvscode.token
#
# Generate token first: 07-openvscode-server.sh with OPENVS_CODE_REQUIRE_TOKEN=1
#   or: python3 -c "import secrets; print(secrets.token_hex(24))" > ~/.config/hermes-bitnet-lxc/openvscode.token

[Unit]
Description=OpenVSCode Server (token auth, all interfaces)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HOME=%h
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HERMES_CHAT_COMPLETIONS_NO_TOOLS=1
WorkingDirectory=%h
ExecStart=%h/.local/bin/openvscode-server --host 0.0.0.0 --port 3010 --connection-token-file %h/.config/hermes-bitnet-lxc/openvscode.token --accept-server-license-terms
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
