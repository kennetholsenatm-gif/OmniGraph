# User systemd unit — install to ~/.config/systemd/user/openvscode-server.service
# Requires: 07-openvscode-server.sh (token file + unpacked release).
#
#   mkdir -p ~/.config/systemd/user
#   cp systemd/openvscode-server.service.example ~/.config/systemd/user/openvscode-server.service
#   systemctl --user daemon-reload
#   systemctl --user enable --now openvscode-server
#   loginctl enable-linger "$USER"   # optional: survive logout
#
# Security: never expose --without-connection-token on untrusted networks.

[Unit]
Description=OpenVSCode Server (browser IDE)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=HOME=%h
WorkingDirectory=%h
# Port 3010 default (avoids Gitea and others on 3000). Match OPENVS_CODE_PORT from 07-openvscode-server.sh or use systemctl edit drop-in.
ExecStart=%h/.local/bin/openvscode-server --host 0.0.0.0 --port 3010 --connection-token-file %h/.config/hermes-bitnet-lxc/openvscode.token
Restart=on-failure
RestartSec=5

[Install]
WantedBy=default.target
