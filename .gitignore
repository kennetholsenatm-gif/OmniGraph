# IDE / editor
.cursor/

# Local dev and secrets — never commit
.dev/
*.key
*.pem
.env
.env.local
*.env.*.local
# Vault payloads with secret values
vault-payload-*.json
vault-payload-*.yaml
# Greenfield identity list (real names/emails; use identities.example.yaml as template)
identities.yaml
identities.ldif
ldap-directory.yaml

# Local debug / agent logs
debug-*.log

# Python cache under scripts/
scripts/__pycache__/

# Ansible network inventory / group_vars with real IPs and secrets (use *.example templates)
ansible/inventory/network.yml
ansible/inventory/mini-pc-iam.yml
ansible/group_vars/network_isr.yml
# Local SSH pubkey for IaC user (use files/ssh/iac.pub.example as template)
ansible/roles/cisco_isr_platform/files/ssh/iac.pub
ansible/group_vars/network_c3560cx.yml

# Local Semaphore GitOps manifest (copy from ansible/files/semaphore-manifest.example.yml)
ansible/files/semaphore-manifest.yml

# Optional large wiki exports (clone stays small; use docs/snippets as source templates)
docs/WIKI_EXPORT/

# Local Semaphore bind mounts (copy from docker-compose.override.example.yml)
deployments/local-control/semaphore/docker-compose.override.yml

# Bootstrap USB bundle build output (large; run build-bundle.sh locally)
deployments/bootstrap-usb-bundle/out/

# Local Go build output (e.g. go build -o bin/omnigraph)
/bin/
