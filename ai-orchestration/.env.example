# AI Orchestration – aggregate .env.example (Phase 5)
# Copy to .env and fill values; do not commit .env.

# --- LLM / AI providers ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# or GEMINI_API_KEY=

# --- GitHub (MCP server, automation) ---
GITHUB_TOKEN=

# --- n8n (existing devsecops-n8n; create API key in Settings → API) ---
N8N_API_KEY=
N8N_BASE_URL=http://n8n:5678
N8N_API_URL=http://n8n:5678
# n8n-mcp port on host (optional overlay)
N8N_MCP_PORT=3001

# --- Solace (from secrets-bootstrap / Vault at secret/devsecops) ---
SOLACE_BROKER_WS_URL=ws://solace-pubsub:8008
SOLACE_USERNAME=admin
SOLACE_PASSWORD=
SOLACE_ADMIN_PASSWORD=
SOLACE_VPN=default

# --- Solace Agent Mesh (devsecops-sam) ---
LLM_SERVICE_ENDPOINT=
LLM_SERVICE_API_KEY=

# --- code-server (Phase 1) ---
CODE_SERVER_PASSWORD=
CODE_SERVER_PORT=8080

# --- OpenCode / Cline (if configurable via env) ---
# OPENCODE_API_KEY=
# CLINE_API_KEY=
