#!/usr/bin/env bash
# Pre-commit hook for OmniGraph Policy-as-Code validation
# This hook validates Rego policies and schema files before commit

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Find omnigraph binary
OMNIGRAPH="${OMNIGRAPH:-omnigraph}"

# Check if omnigraph is available
if ! command -v "$OMNIGRAPH" &> /dev/null; then
    echo -e "${RED}Error: omnigraph command not found${NC}"
    echo "Please install OmniGraph or set OMNIGRAPH environment variable"
    exit 1
fi

# Get list of staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Filter for policy and schema files
POLICY_FILES=()
SCHEMA_FILES=()

for file in $STAGED_FILES; do
    case "$file" in
        *.rego)
            POLICY_FILES+=("$file")
            ;;
        *.yaml|*.yml)
            # Check if it's a policy file
            if grep -q "omnigraph/policy/v1" "$file" 2>/dev/null; then
                POLICY_FILES+=("$file")
            fi
            ;;
        *.json)
            # Check if it's a policy file
            if grep -q "omnigraph/policy/v1" "$file" 2>/dev/null; then
                POLICY_FILES+=("$file")
            fi
            ;;
        *.omnigraph.schema|.omnigraph.schema)
            SCHEMA_FILES+=("$file")
            ;;
    esac
done

# Exit early if no relevant files
if [ ${#POLICY_FILES[@]} -eq 0 ] && [ ${#SCHEMA_FILES[@]} -eq 0 ]; then
    echo -e "${GREEN}No policy or schema files to validate${NC}"
    exit 0
fi

echo -e "${YELLOW}OmniGraph Policy Validation${NC}"
echo "================================"

# Validate policy files
if [ ${#POLICY_FILES[@]} -gt 0 ]; then
    echo -e "\n${YELLOW}Validating policy files...${NC}"
    
    for policy_file in "${POLICY_FILES[@]}"; do
        echo -n "  Checking $policy_file... "
        
        # Validate policy syntax
        if $OMNIGRAPH policy validate "$policy_file" > /dev/null 2>&1; then
            echo -e "${GREEN}OK${NC}"
        else
            echo -e "${RED}FAILED${NC}"
            echo -e "${RED}Policy validation failed for: $policy_file${NC}"
            $OMNIGRAPH policy validate "$policy_file"
            exit 1
        fi
    done
    
    echo -e "${GREEN}All policy files validated successfully${NC}"
fi

# Validate schema files with policy checks
if [ ${#SCHEMA_FILES[@]} -gt 0 ]; then
    echo -e "\n${YELLOW}Validating schema files with policy checks...${NC}"
    
    # Check if policies directory exists
    POLICY_DIR=""
    if [ -d "policies" ]; then
        POLICY_DIR="policies"
    elif [ -d "testdata/policies" ]; then
        POLICY_DIR="testdata/policies"
    fi
    
    for schema_file in "${SCHEMA_FILES[@]}"; do
        echo -n "  Checking $schema_file... "
        
        # Build validation command
        VALIDATE_CMD="$OMNIGRAPH validate $schema_file"
        
        # Add policy directory if it exists
        if [ -n "$POLICY_DIR" ]; then
            VALIDATE_CMD="$VALIDATE_CMD --policy-dir $POLICY_DIR --enforce"
        fi
        
        # Validate schema
        if $VALIDATE_CMD > /dev/null 2>&1; then
            echo -e "${GREEN}OK${NC}"
        else
            echo -e "${RED}FAILED${NC}"
            echo -e "${RED}Schema validation failed for: $schema_file${NC}"
            $VALIDATE_CMD
            exit 1
        fi
    done
    
    echo -e "${GREEN}All schema files validated successfully${NC}"
fi

# Run policy check if policies directory exists
if [ -d "policies" ] || [ -d "testdata/policies" ]; then
    echo -e "\n${YELLOW}Running policy checks...${NC}"
    
    POLICY_DIR="policies"
    if [ -d "testdata/policies" ]; then
        POLICY_DIR="testdata/policies"
    fi
    
    # List available policy sets
    echo "  Available policy sets:"
    $OMNIGRAPH policy list --policy-dir "$POLICY_DIR" 2>/dev/null | grep -E "^[a-z]" | while read -r line; do
        echo "    - $line"
    done
    
    echo -e "${GREEN}Policy checks completed${NC}"
fi

echo -e "\n${GREEN}All validations passed!${NC}"
exit 0