---
# Copy to network_isr.yml and edit. HashiCorp Vault is NOT required for lab use.
#
# 1) SSH from Ansible to the ISR (network_cli):
#    - ansible_user should be `iac` (matches inventory and cisco_isr_admin_username).
#    - Set ansible_password in inventory vars, or use: ansible-playbook ... --ask-pass
#
# 2) IOS local automation user `iac` (cisco.ios.ios_user — password ± optional pubkey):
#    - Set cisco_isr_admin_password below (rotate after bootstrap).
#
# 3) Human admin `kbolsen` (separate IOS user — SSH key only / nopassword; NOT ansible_user):
#    - Default: role loads files/ssh/kbolsen.pub. Override with cisco_isr_human_admin_ssh_pubkey if needed.
#    - To skip creating kbolsen on-box: cisco_isr_human_admin_enabled: false

# Example — uncomment and set (or use extra-vars; keep secrets out of git):
# cisco_isr_admin_password: "your-ios-user-password"

# Optional — automation user pubkey (if not using files/ssh/iac.pub):
# cisco_isr_admin_ssh_pubkey: "ssh-ed25519 AAAA... iac@host"
# cisco_isr_admin_ssh_pubkey_file: "ssh/iac.pub"

# --- rest of ISR role (copy from your network_isr.yml or defaults) ---
cisco_isr_wan_interface: GigabitEthernet0/0/0
cisco_isr_inside_interface: GigabitEthernet0/0/1
cisco_isr_inside_subinterfaces: []
cisco_isr_configure_nat_overload: false

# --- UCS-E (ISR4k SM): enable + optional extra subslots for no shutdown ---
# cisco_isr_ucse_enabled: true
# cisco_isr_ucse_extra_subslots: ["1/0", "2/0"]
# cisco_isr_ucse_modules: []   # or full dicts per defaults/main.yml (L3 + IMC)

# --- Data-plane: WAN inbound extended ACL (off by default — validate lines first) ---
# cisco_isr_wan_infrastructure_acl:
#   enabled: true
#   # name / lines default from role; override `lines` here if your WAN is static-only (drop DHCP ACEs).

# --- Control-plane: CoPP-style policy on control-plane host (off by default) ---
# cisco_isr_copp_enabled: true
# cisco_isr_copp_police_rate_percent: 10

# Restrict SSH sources to management subnets (standard ACL must exist on device):
# cisco_isr_vty_access_class: MGMT-SSH-IN

# --- OpenNebula + Gitea edge (refined plan) — VLAN_MATRIX.md ---
# Trunk toward core/switch must allow at minimum: 86, 2001, 2005, 2250 (+ platform 240-244).
# If ISR inside is L3 subinterfaces, add each as a dict under cisco_isr_inside_subinterfaces
# (example VLAN IDs; set ipv4/mask to your deployment):
# cisco_isr_inside_trunk_allowed_vlans: "240,244,86,2001,2005,2250"
# cisco_isr_inside_subinterfaces:
#   - { vlan: 2001, ipv4: 100.64.1.1, mask: 255.255.255.0, description: SVI_GW_devsecops-gitea }
#   - { vlan: 2005, ipv4: 100.64.5.1, mask: 255.255.255.0, description: SVI_GW_devsecops-gateway }
#   - { vlan: 2250, ipv4: 100.64.250.1, mask: 255.255.255.0, description: SVI_GW_devsecops-ceph_optional }
# Static route to 100.64.0.0/10 via OpenNebula VR next-hop (see VLAN_MATRIX Virtual Router):
# cisco_isr_static_routes:
#   - { prefix: 100.64.0.0, mask: 255.192.0.0, next_hop: 192.168.86.2 }
