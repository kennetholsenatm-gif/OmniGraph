# Copy to devsecops_secrets.yml and fill values; then: ansible-vault encrypt group_vars/ai_mesh_nodes/devsecops_secrets.yml
# Do not commit devsecops_secrets.yml without encryption. Keys match devsecops.env.schema.
---
devsecops_secrets:
  # Bootstrap only (first Keycloak init); prefer KEYCLOAK_AUTOMATION_CLIENT_* for scripts (docs/IAM_LDAP_AND_AUTOMATION.md)
  KEYCLOAK_ADMIN: ""
  KEYCLOAK_ADMIN_PASSWORD: ""
  KEYCLOAK_AUTOMATION_CLIENT_ID: "devsecops-automation"
  KEYCLOAK_AUTOMATION_CLIENT_SECRET: ""
  KEYCLOAK_DB_PASSWORD: ""
  GITEA_API_TOKEN: ""
  ZAMMAD_POSTGRES_PASSWORD: ""
  ZAMMAD_API_TOKEN: ""
  SOLACE_PASSWORD: ""
  SOLACE_ADMIN_PASSWORD: ""
  WEBHOOK_HMAC_SECRET: ""
  # Gitea webhook secret for POST /webhook/docs-sync (Docsify volume refresh); optional
  GITEA_DOCS_WEBHOOK_SECRET: ""
  # SonarQube (messaging sonar-db-init + tooling sonarqube)
  SONAR_JDBC_PASSWORD: ""
  SONARQUBE_OIDC_CLIENT_SECRET: ""
  N8N_API_TOKEN: ""
  TELEPORT_API_TOKEN: ""
  GATEWAY_REFRESH_SECRET: ""
  BITWARDEN_ADMIN_TOKEN: ""
  # VAULT_DEV_ROOT_TOKEN_ID if using dev server
  # Add other @sensitive keys from devsecops.env.schema and gateway.env.schema
