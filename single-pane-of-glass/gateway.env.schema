# VARLOCK env-spec — Single Pane of Glass gateway.
# No raw secrets; inject at runtime (Vault, .env). Use @type=port, @sensitive as required.

@version: "1.0"
@description: "Gateway: Traefik, dashboard, knowledge base, webhook listener. Zero Trust, mTLS, Keycloak, Teleport JIT."

# --- Gateway / Traefik ---
@env-spec: GATEWAY
GATEWAY_DOMAIN: string
@description: "Public hostname for the gateway (e.g. localhost or gateway.example.com)"
@default: "localhost"

GATEWAY_HTTP_PORT: integer
@type: port
@default: 80
@description: "Host port for HTTP (redirects to HTTPS)"

GATEWAY_HTTPS_PORT: integer
@type: port
@default: 443
@description: "Host port for HTTPS"

GATEWAY_REFRESH_SECRET: string
@sensitive: true
@required: false
@description: "Shared secret for dashboard refresh (webhook-listener -> dashboard /api/refresh). Inject from Vault."

# --- Keycloak (SSO / forward auth) ---
@env-spec: KEYCLOAK_GATEWAY
KEYCLOAK_URL: string
@description: "Keycloak base URL (internal, e.g. http://keycloak:8080)"
@default: "http://keycloak:8080"

KEYCLOAK_REALM: string
@default: "master"

KEYCLOAK_CLIENT_ID: string
@description: "Keycloak client ID for gateway forward auth"
@required: false

KEYCLOAK_CLIENT_SECRET: string
@sensitive: true
@required: false
@description: "Keycloak client secret; inject from Vault"

# --- Gitea (wiki / knowledge base) ---
@env-spec: GITEA_WIKI
GITEA_URL: string
@default: "http://gitea:3000"

GITEA_API_TOKEN: string
@sensitive: true
@required: true
@description: "Gitea API token for wiki/repo read; inject from Vault"

GITEA_WIKI_OWNER: string
@description: "Gitea org or user that owns the wiki repo"
@required: false

GITEA_WIKI_REPO: string
@description: "Gitea repo name used as wiki (SAM Doc Agent output)"
@required: false

# --- Webhook (SAM / n8n doc-push) ---
@env-spec: WEBHOOK
WEBHOOK_HMAC_SECRET: string
@sensitive: true
@required: false
@description: "HMAC secret for webhook signature verification (e.g. Gitea or n8n); inject from Vault"

# --- Docsify sync (Gitea → gateway /webhook/docs-sync) ---
@env-spec: DOCS_SYNC_WEBHOOK
DOCS_SYNC_ENABLED: string
@default: "false"
@description: "When true, POST /webhook/docs-sync verifies Gitea signature and starts docs-sync container (requires Docker socket mount on webhook-listener)"

DOCS_SYNC_CONTAINER_NAME: string
@default: "devsecops-docs-sync"
@description: "Container name to docker start (must match docker-compose.tooling.yml)"

GITEA_DOCS_WEBHOOK_SECRET: string
@sensitive: true
@required: false
@description: "Same secret as configured on the Gitea webhook; used for X-Gitea-Signature HMAC"

DOCS_SYNC_REPO_FULL_NAME: string
@required: false
@default: ""
@description: "Optional: only sync when repository.full_name matches (e.g. DevSecOps/architecture-docs)"

DOCKER_SOCK: string
@default: "/var/run/docker.sock"
@description: "Unix socket path for Docker Engine API inside webhook-listener"

# --- LMNotebook / OpenCode ---
@env-spec: LMNOTEBOOK
LMNOTEBOOK_URL: string
@description: "URL to embed GPT-OSS / LMNotebooks / OpenCode in the dashboard (empty = placeholder only)"
@default: ""
@required: false

# --- Network (OpenTofu) ---
@env-spec: GATEWAY_NETWORK
TOOLING_GATEWAY_CIDR: string
@default: "100.64.5.0/24"
