# Single Pane of Glass — structural example. No secrets in repo.
# Copy to .env and set values; inject secrets from Vault (Varlock). See gateway.env.schema.

# Gateway
GATEWAY_DOMAIN=localhost
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443
GATEWAY_REFRESH_SECRET=

# Keycloak (forward auth; optional)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=

# Gitea wiki (knowledge base)
GITEA_URL=http://gitea:3000
GITEA_API_TOKEN=
GITEA_WIKI_OWNER=
GITEA_WIKI_REPO=

# Webhook (SAM / n8n doc-push)
WEBHOOK_HMAC_SECRET=

# Docsify: Gitea push → POST /webhook/docs-sync (Docker socket on webhook-listener; see docs/DOCSIFY_GITEA.md)
DOCS_SYNC_ENABLED=false
DOCS_SYNC_CONTAINER_NAME=devsecops-docs-sync
GITEA_DOCS_WEBHOOK_SECRET=
DOCS_SYNC_REPO_FULL_NAME=

# LMNotebook embed URL
LMNOTEBOOK_URL=
