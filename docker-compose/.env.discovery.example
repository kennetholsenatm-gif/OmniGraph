# Copy to docker-compose/.env (merge with existing) for docker-compose.discovery.yml
# Values should come from Vault / Varlock — never commit real secrets.

NETBOX_DB_PASSWORD=change-me
NETBOX_REDIS_PASSWORD=change-me
NETBOX_SECRET_KEY=change-me-long-random-django-secret
NETBOX_SUPERUSER_PASSWORD=change-me
NETBOX_SUPERUSER_NAME=admin
NETBOX_SUPERUSER_EMAIL=admin@example.com
