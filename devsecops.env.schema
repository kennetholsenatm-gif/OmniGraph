# VARLOCK Environment Schema — Autonomous Zero Trust DevSecOps Pipeline
# Unified schema for n8n, SAM, agents, Gitea, Zammad, Teleport, Solace.
# No raw secrets; values injected at runtime (Vault, .env, or secret manager).
# Hostnames use Docker service names or 100.64.x.x; no internal.mesh in defaults.

@version: "1.0"
@description: "Environment variables for Zero Trust DevSecOps pipeline (n8n, SAM, Gitea, Zammad, Teleport, Solace)"
@compliance: "CMMC Level 2, Post-Quantum Cryptography Ready"

# --- Core Application ---
@env-spec: CORE
APP_ENV: string
@description: "Operational environment"
@default: "development"
@validation: "must be development, staging, or production"

INTERNAL_BIND_PORT: integer
@description: "Internal binding port for microservices"
@default: 8080

LOG_LEVEL: string
@default: "INFO"
@validation: "DEBUG, INFO, WARN, ERROR"

LOG_FORMAT: string
@default: "json"
@validation: "json or text"

# --- Database (shared / per-service) ---
@env-spec: DATABASE
DATABASE_URL: string
@sensitive: true
@required: true
@description: "Primary connection string; loaded securely at runtime"

# --- Phase 4 Data Fabric: Messaging Postgres (NiFi, Kafka Connect, pipeline_events) ---
@env-spec: MESSAGING_POSTGRES
POSTGRES_HOST: string
@description: "Postgres host for messaging stack (NiFi, Kafka Connect); Docker service name"
@default: "postgres"

POSTGRES_PORT: string
@default: "5432"

POSTGRES_USER: string
@default: "qminiwasm"
@description: "Postgres user for docker-compose.messaging.yml (postgres, nifi, kafka-connect)"

POSTGRES_PASSWORD: string
@sensitive: true
@required: true
@description: "Postgres password for messaging stack; inject from Vault"

POSTGRES_DB: string
@default: "qminiwasm_db"
@description: "Database name (pgvector); pipeline.pipeline_events lives here"

# --- DevSecOps Pipeline: Gitea ---
@env-spec: GITEA
GITEA_REPO_URL: string
@description: "Gitea repository URL for autonomous modifications"
@default: "http://gitea:3000/ai_pipeline/project-omega"

GITEA_API_TOKEN: string
@sensitive: true
@required: true
@description: "Gitea API token for repository and wiki operations"

GITEA_URL: string
@description: "Gitea base URL (Docker service or host)"
@default: "http://gitea:3000"

GITEA_DATA_PATH: string
@description: "Host path for Gitea server data (repos, DB, config). Windows lab default below; on OpenNebula/Linux use a POSIX path or omit when Gitea runs only on PVCs — see docs/opennebula-gitea-edge/WHOLE-REPO-MIGRATION-SCOPE.md"
@default: "C:/GiTeaRepos"

GITEA_REPOS_ROOT: string
@description: "Working-copy root for scripts/docs (Windows: C:\\GiTeaRepos). After migration set to Linux canonical clone path (e.g. /opt/GiTeaRepos) and align README/CI."
@default: "C:\\GiTeaRepos"

WEBHOOK_HMAC_SECRET: string
@sensitive: true
@required: true
@description: "Webhook HMAC secret for Gitea webhook signature"

# --- Docsify (architecture-docs via Nginx + git sync) ---
@env-spec: DOCSIFY
DOCS_GIT_REPO: string
@description: "Git clone URL for Docsify static site (internal: http://gitea:3000/Org/repo.git). For private repos embed token per docs/DOCSIFY_GITEA.md."
@default: "http://gitea:3000/DevSecOps/architecture-docs.git"

DOCS_GIT_BRANCH: string
@description: "Branch to clone/fetch for docs volume"
@default: "main"

DOCS_SYNC_ENABLED: string
@description: "When true, gateway webhook-listener accepts POST /webhook/docs-sync and starts docs-sync via Docker socket"
@default: "false"

DOCS_SYNC_CONTAINER_NAME: string
@description: "Docker container name for one-shot git sync (must match tooling compose container_name)"
@default: "devsecops-docs-sync"

GITEA_DOCS_WEBHOOK_SECRET: string
@sensitive: true
@required: false
@description: "Gitea webhook secret for X-Gitea-Signature verification on /webhook/docs-sync; inject from Vault"

DOCS_SYNC_REPO_FULL_NAME: string
@description: "Optional filter: only run sync when payload.repository.full_name matches (e.g. DevSecOps/architecture-docs)"
@required: false
@default: ""

# --- SonarQube (tooling + messaging Postgres) ---
@env-spec: SONARQUBE
SONAR_JDBC_DB: string
@description: "Postgres database name for SonarQube (must match sonar-db-init)"
@default: "sonar"

SONAR_JDBC_USERNAME: string
@default: "sonar"

SONAR_JDBC_PASSWORD: string
@sensitive: true
@required: false
@description: "DB password for SonarQube role; generated in secrets-bootstrap when using SonarQube. If unset, sonar-db-init skips (messaging still starts)."

SONAR_WEB_CONTEXT: string
@description: "Web context path behind Traefik (leading slash)"
@default: "/sonarqube"

SONAR_WEB_JAVAOPTS: string
@description: "JVM options for SonarQube web process"
@default: "-Xmx2g -Xms512m"

SONARQUBE_OIDC_CLIENT_SECRET: string
@sensitive: true
@required: false
@description: "Keycloak confidential client secret for SonarQube Developer+ SAML/OIDC; Community uses proxy/headers per docs/SONARQUBE_KEYCLOAK.md"

# --- Wazuh SIEM (docker-compose.siem.yml) ---
@env-spec: WAZUH_SIEM
WAZUH_INDEXER_PASSWORD: string
@sensitive: true
@required: false
@description: "Indexer admin user password; must match opensearch internal_users.yml hashes if changed from upstream demo (see docs/WAZUH_SIEM.md)"
@default: "SecretPassword"

WAZUH_MANAGER_API_PASSWORD: string
@sensitive: true
@required: false
@description: "Wazuh API (wazuh-wui) password passed to manager and dashboard containers"
@default: "MyS3cr37P450r.*-"

WAZUH_DASHBOARD_KIBANA_PASSWORD: string
@sensitive: true
@required: false
@description: "OpenSearch Dashboards kibanaserver user password; must match internal_users.yml"
@default: "kibanaserver"

# --- Phase 2 IAM: Keycloak OIDC (Gitea, n8n, Zammad) ---
@env-spec: IAM_OIDC
GATEWAY_DOMAIN: string
@description: "Public hostname for gateway (Traefik); used by Keycloak for redirect URIs"
@default: "localhost"

GATEWAY_BASE_URL: string
@description: "Public base URL for redirect URIs (e.g. http://localhost or https://gateway.example.com). No trailing slash."
@default: "http://localhost"

KEYCLOAK_PUBLIC_URL: string
@description: "Keycloak base URL as seen by the browser (e.g. http://localhost/keycloak)"
@default: "http://localhost/keycloak"

KEYCLOAK_REALM: string
@description: "Keycloak realm for OIDC clients"
@default: "master"

GITEA_OIDC_CLIENT_ID: string
@default: "gitea"
@description: "Keycloak OIDC client ID for Gitea"

GITEA_OIDC_CLIENT_SECRET: string
@sensitive: true
@required: false
@description: "Keycloak OIDC client secret for Gitea; inject from Vault"

N8N_EDITOR_BASE_URL: string
@description: "Public URL of n8n editor (for OIDC redirect)"
@default: "http://localhost/n8n"

N8N_OIDC_CLIENT_ID: string
@default: "n8n"
@description: "Keycloak OIDC client ID for n8n"

N8N_OIDC_CLIENT_SECRET: string
@sensitive: true
@required: false
@description: "Keycloak OIDC client secret for n8n; inject from Vault"

ZAMMAD_PUBLIC_URL: string
@description: "Public URL of Zammad (for OIDC callback)"
@default: "http://localhost/zammad"

# --- DevSecOps Pipeline: n8n ---
@env-spec: N8N
N8N_WEBHOOK_URL: string
@description: "n8n webhook base URL for pipeline triggers"
@default: "http://n8n:5678"

N8N_API_TOKEN: string
@sensitive: true
@required: true
@description: "n8n API token for workflow integration"

N8N_HOST: string
@default: "n8n"
@description: "n8n host (Docker service name)"

# License/activation key (managed via KMS/Vault; never in .env). See docs/LICENSE_KEYS_KMS.md.
N8N_LICENSE_ACTIVATION_KEY: string
@sensitive: true
@required: false
@description: "n8n license activation key; inject from Vault at runtime. Set in Vault at secret/devsecops or secret/licenses."

# --- DevSecOps Pipeline: Zammad ---
@env-spec: ZAMMAD
ZAMMAD_URL: string
@description: "Zammad base URL for ITSM and webhooks"
@default: "http://zammad:80"

ZAMMAD_API_TOKEN: string
@sensitive: true
@required: true
@description: "Zammad API token for ticket updates and webhook auth"

# --- Solace Event Broker (A2A messaging) ---
@env-spec: SOLACE_BROKER
SOLACE_BROKER_URL: string
@description: "Solace broker connection URL (SMF or MQTT)"
@default: "tcp://solace-pubsub:55555"

SOLACE_BROKER_WS_URL: string
@description: "Solace WebSocket URL for SAM/n8n"
@default: "ws://solace-pubsub:8008"

SOLACE_VPN: string
@default: "discovery_tools_mesh"

SOLACE_USERNAME: string
@default: "admin"

SOLACE_PASSWORD: string
@sensitive: true
@required: true
@description: "Solace broker password (not used when mTLS-only)"

SOLACE_TLS_ENABLED: boolean
@default: true

SOLACE_CLIENT_CERT_PATH: string
@default: "/opt/mesh_secrets/certs/node_client.crt"

SOLACE_CLIENT_KEY_PATH: string
@default: "/opt/mesh_secrets/certs/node_client.key"

# --- Teleport (JIT access) ---
@env-spec: TELEPORT
TELEPORT_PROXY: string
@description: "Teleport proxy address (host or service name)"
@default: "teleport"

TELEPORT_AUTH_SERVER: string
@default: "teleport:3025"

TELEPORT_API_TOKEN: string
@sensitive: true
@required: true
@description: "Teleport API token for JIT / access request approval"

TELEPORT_JIT_REQUEST_URL: string
@description: "Custom JIT request endpoint (n8n calls this)"
@default: "https://teleport/api/v1/jit/request"

# --- Admin (single admin identity; store in Vault) ---
@env-spec: ADMIN
# IAM: KEYCLOAK_ADMIN / KEYCLOAK_ADMIN_PASSWORD are bootstrap-only (first Keycloak init). Prefer LDAP for admin and KEYCLOAK_AUTOMATION_CLIENT_* for scripts (docs/IAM_LDAP_AND_AUTOMATION.md). admin_ssh_public_key is the same admin's SSH public key for Gitea/Teleport/etc.
KEYCLOAK_AUTOMATION_CLIENT_ID: string
@default: "devsecops-automation"
@description: "Keycloak service-account client for scripts/Ansible; store secret in Vault as KEYCLOAK_AUTOMATION_CLIENT_SECRET"

KEYCLOAK_AUTOMATION_CLIENT_SECRET: string
@sensitive: true
@required: false
@description: "Keycloak service-account client secret; inject from Vault for automation (no admin password)"
admin_ssh_public_key: string
@description: "SSH public key for admin user (e.g. kbolsen); used for Git and service admin access"
@sensitive: false
@required: false

admin_mfa_email: string
@description: "Email for admin MFA (OTP, recovery, or identity binding); e.g. kenneth.olsen.atm@gmail.com"
@default: "kenneth.olsen.atm@gmail.com"
@sensitive: false
@required: false

# --- Vault (secrets) ---
@env-spec: VAULT
VAULT_ADDR: string
@default: "http://vault:8200"

VAULT_TOKEN: string
@sensitive: true
@required: true

VAULT_SECRET_PATH: string
@default: "secret/devsecops"

# --- 1-bit LLM / BitNet (optional for SAM and n8n agents) ---
@env-spec: LLM_SERVICE
LLM_SERVICE_ENDPOINT: string
@description: "Local 1-bit LLM or BitNet endpoint (optional)"
@default: ""

LLM_SERVICE_API_KEY: string
@sensitive: true
@required: false

LLM_SERVICE_PLANNING_MODEL_NAME: string
@default: ""

LLM_SERVICE_GENERAL_MODEL_NAME: string
@default: ""

# --- Security & Compliance ---
@env-spec: SECURITY_COMPLIANCE
SECURITY_COMPLIANCE: string
@default: "CMMC_L2"
@validation: "CMMC_L2, STIG, PQC_READY"

PQC_KEM_SEED: string
@sensitive: true
@required: false
@description: "64-byte seed for ML-KEM post-quantum key encapsulation"

CMMC_LEVEL: string
@default: "Level 2"

# --- Network (100.64.0.0/10) ---
@env-spec: NETWORK
TOOLING_GITEA_CIDR: string
@default: "100.64.1.0/24"

TOOLING_N8N_CIDR: string
@default: "100.64.2.0/24"

TOOLING_ZAMMAD_CIDR: string
@default: "100.64.3.0/24"

TOOLING_BITWARDEN_CIDR: string
@default: "100.64.4.0/24"

# --- Bitwarden (Vaultwarden — human password manager) ---
@env-spec: BITWARDEN
BITWARDEN_DOMAIN: string
@description: "Public URL for Bitwarden clients (e.g. http://localhost:8484 or https://bitwarden.example.com)"
@default: "http://localhost:8484"

BITWARDEN_PORT: integer
@type: port
@description: "Host port for Vaultwarden web UI"
@default: 8484

BITWARDEN_ADMIN_TOKEN: string
@sensitive: true
@required: false
@description: "Admin panel token; inject from Vault. If unset, admin panel is disabled."

BITWARDEN_SIGNUPS_ALLOWED: boolean
@default: true
@description: "Allow new user signups"

BITWARDEN_INVITATIONS_ALLOWED: boolean
@default: true
@description: "Allow organization invitations"

MSG_BACKBONE_CIDR: string
@default: "100.64.10.0/24"

IAM_CIDR: string
@default: "100.64.20.0/24"

FREEIPA_CIDR: string
@default: "100.64.21.0/24"
@description: "Subnet for optional FreeIPA stack (freeipa_net)"

AGENT_MESH_CIDR: string
@default: "100.64.30.0/24"

LLM_NET_CIDR: string
@default: "100.64.7.0/24"
@description: "Subnet for llm_net (BitNet / LLM gateway)"

CHATOPS_NET_CIDR: string
@default: "100.64.8.0/24"
@description: "Subnet for chatops_net (Zulip, etc.)"

DISCOVERY_NET_CIDR: string
@default: "100.64.40.0/24"
@description: "Subnet for discovery_net (NetBox, NetDISCO, Dependency-Track)"

TOOLING_GATEWAY_CIDR: string
@default: "100.64.5.0/24"
@description: "Subnet for gateway_net (Traefik)"

TOOLING_PORTAINER_CIDR: string
@default: "100.64.6.0/24"
@description: "Subnet for portainer_net"

# --- Discovery / BOM (optional) ---
@env-spec: DISCOVERY_ORCHESTRATION
DISCOVERY_NETWORK_SUBNET: string
@default: "100.64.40.0/24"
@description: "Primary discovery segment; prefer DISCOVERY_NET_CIDR / discovery_net"

DISCOVERY_ORCHESTRATOR_ENABLED: boolean
@default: true

N8N_WEBHOOK_DISCOVERY_URL: string
@default: "http://n8n:5678/webhook/discovery-events"

# --- NetBox (discovery_net) ---
@env-spec: NETBOX
NETBOX_URL: string
@description: "NetBox base URL (e.g. http://netbox:8080 on discovery_net)"
@default: "http://netbox:8080"

NETBOX_API_TOKEN: string
@sensitive: true
@required: false
@description: "NetBox REST API token; create in NetBox UI after bootstrap"

NETBOX_DB_PASSWORD: string
@sensitive: true
@required: false
@description: "Postgres password for NetBox in docker-compose.discovery.yml"

NETBOX_REDIS_PASSWORD: string
@sensitive: true
@required: false
@description: "Redis password for NetBox worker/queue"

NETBOX_SECRET_KEY: string
@sensitive: true
@required: false
@description: "Django SECRET_KEY for NetBox"

NETBOX_SUPERUSER_NAME: string
@default: "admin"
@required: false

NETBOX_SUPERUSER_EMAIL: string
@default: "admin@example.com"
@required: false

NETBOX_SUPERUSER_PASSWORD: string
@sensitive: true
@required: false
@description: "Initial NetBox superuser password (rotate after first login)"

# --- NetDISCO (optional) ---
@env-spec: NETDISCO
NETDISCO_SNMP_COMMUNITY: string
@sensitive: true
@required: false
@description: "SNMP read-only community (or reference Vault path); never commit"

NETDISCO_API_TOKEN: string
@sensitive: true
@required: false
@description: "If exposing NetDISCO HTTP API with auth"

# --- Dependency-Track (discovery_net) ---
@env-spec: DEP_TRACK
DEP_TRACK_URL: string
@default: "http://dependency-track:8080"
@description: "Dependency-Track base URL (bundled image internal port 8080)"

DEP_TRACK_API_KEY: string
@sensitive: true
@required: false
@description: "Automation API key from Dep-Track UI"

# --- Termius (NetBox sync) ---
@env-spec: TERMIUS
TERMIUS_SYNC_MODE: string
@default: "import_json"
@description: "import_json | teams_api — see scripts/sync_netbox_to_termius.py"

TERMIUS_TEAMS_API_BASE: string
@default: ""
@required: false
@description: "Base URL for Termius Teams API (set per vendor docs); no secrets in repo"

TERMIUS_API_TOKEN: string
@sensitive: true
@required: false
@description: "Bearer or API token for Termius Teams; inject from Vault only"

TERMIUS_SSH_USERNAME_DEFAULT: string
@default: ""
@required: false
@description: "Default SSH username when NetBox has none (optional)"

TERMIUS_SSH_KEY_PATH: string
@default: ""
@required: false
@description: "Host path to private key for Termius import metadata only — prefer agent/Termius keychain"

# --- SDN + telemetry (docker-compose.network.yml / docker-compose.telemetry.yml) ---
@env-spec: SDN_TELEMETRY
VYOS_USER: string
@default: "vyos"
@description: "VyOS container login user (lab)"

VYOS_USER_PASSWORD: string
@sensitive: true
@required: false
@description: "VyOS password; inject from Vault / secrets-bootstrap"

VYOS_ENROLL_KEY: string
@sensitive: true
@required: false
@description: "Optional enrollment/bootstrap key for VyOS automation"

GRAFANA_ADMIN_USER: string
@default: "admin"
@description: "Grafana local admin username"

GRAFANA_ADMIN_PASSWORD: string
@sensitive: true
@required: false
@description: "Grafana admin password; inject from Vault"

GRAFANA_ROOT_URL: string
@default: "http://localhost/grafana"
@description: "Public URL for Grafana (Traefik path /grafana)"

GRAFANA_OIDC_ENABLED: string
@default: "false"
@description: "Set true after Keycloak client and GRAFANA_OIDC_CLIENT_SECRET exist"

GRAFANA_OIDC_CLIENT_ID: string
@default: "grafana"
@description: "Keycloak OIDC client id"

GRAFANA_OIDC_CLIENT_SECRET: string
@sensitive: true
@required: false
@description: "Keycloak confidential client secret for Grafana"

GRAFANA_OIDC_LOGIN_ATTRIBUTE_PATH: string
@default: "preferred_username"
@required: false
@description: "Grafana generic OAuth login claim path (Keycloak default)"

GRAFANA_OIDC_EMAIL_ATTRIBUTE_PATH: string
@default: "email"
@required: false
@description: "Grafana generic OAuth email claim path"

GRAFANA_OIDC_NAME_ATTRIBUTE_PATH: string
@default: "name"
@required: false
@description: "Grafana generic OAuth display name claim path"

SFLOW_RT_ADMIN_TOKEN: string
@sensitive: true
@required: false
@description: "Optional token for sFlow-RT REST hooks (if enabled in app)"

ZULIP_SFLOW_STREAM: string
@default: "network"
@description: "Zulip stream for sFlow anomaly n8n workflow (override in container env)"

DEVSECOPS_INCLUDE_SDN_TELEMETRY: string
@default: ""
@description: "Set to 1 for docker-compose/launch-stack.ps1 to start network + telemetry stacks"

# --- Integration (optional vendor) ---
VENDOR_API_KEY: string
@sensitive: true
@required: false
