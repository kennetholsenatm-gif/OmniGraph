# VARLOCK Environment Schema — Autonomous Zero Trust DevSecOps Pipeline
# Unified schema for n8n, SAM, agents, Gitea, Zammad, Teleport, Solace.
# No raw secrets; values injected at runtime (Vault, .env, or secret manager).
# Hostnames use Docker service names or 100.64.x.x; no internal.mesh in defaults.

@version: "1.0"
@description: "Environment variables for Zero Trust DevSecOps pipeline (n8n, SAM, Gitea, Zammad, Teleport, Solace)"
@compliance: "CMMC Level 2, Post-Quantum Cryptography Ready"

# --- Core Application ---
@env-spec: CORE
APP_ENV: string
@description: "Operational environment"
@default: "development"
@validation: "must be development, staging, or production"

INTERNAL_BIND_PORT: integer
@description: "Internal binding port for microservices"
@default: 8080

LOG_LEVEL: string
@default: "INFO"
@validation: "DEBUG, INFO, WARN, ERROR"

LOG_FORMAT: string
@default: "json"
@validation: "json or text"

# --- Database (shared / per-service) ---
@env-spec: DATABASE
DATABASE_URL: string
@sensitive: true
@required: true
@description: "Primary connection string; loaded securely at runtime"

# --- DevSecOps Pipeline: Gitea ---
@env-spec: GITEA
GITEA_REPO_URL: string
@description: "Gitea repository URL for autonomous modifications"
@default: "http://gitea:3000/ai_pipeline/project-omega"

GITEA_API_TOKEN: string
@sensitive: true
@required: true
@description: "Gitea API token for repository and wiki operations"

GITEA_URL: string
@description: "Gitea base URL (Docker service or host)"
@default: "http://gitea:3000"

GITEA_DATA_PATH: string
@description: "Host path for Gitea server data (repos, DB, config). All Gitea repos live here. Use C:\\GiTeaRepos for canonical location."
@default: "C:/GiTeaRepos"

GITEA_REPOS_ROOT: string
@description: "Host path where Gitea repo clones belong (canonical working-copy location for scripts and docs)"
@default: "C:\\GiTeaRepos"

WEBHOOK_HMAC_SECRET: string
@sensitive: true
@required: true
@description: "Webhook HMAC secret for Gitea webhook signature"

# --- DevSecOps Pipeline: n8n ---
@env-spec: N8N
N8N_WEBHOOK_URL: string
@description: "n8n webhook base URL for pipeline triggers"
@default: "http://n8n:5678"

N8N_API_TOKEN: string
@sensitive: true
@required: true
@description: "n8n API token for workflow integration"

N8N_HOST: string
@default: "n8n"
@description: "n8n host (Docker service name)"

# License/activation key (managed via KMS/Vault; never in .env). See docs/LICENSE_KEYS_KMS.md.
N8N_LICENSE_ACTIVATION_KEY: string
@sensitive: true
@required: false
@description: "n8n license activation key; inject from Vault at runtime. Set in Vault at secret/devsecops or secret/licenses."

# --- DevSecOps Pipeline: Zammad ---
@env-spec: ZAMMAD
ZAMMAD_URL: string
@description: "Zammad base URL for ITSM and webhooks"
@default: "http://zammad:80"

ZAMMAD_API_TOKEN: string
@sensitive: true
@required: true
@description: "Zammad API token for ticket updates and webhook auth"

# --- Solace Event Broker (A2A messaging) ---
@env-spec: SOLACE_BROKER
SOLACE_BROKER_URL: string
@description: "Solace broker connection URL (SMF or MQTT)"
@default: "tcp://solace-pubsub:55555"

SOLACE_BROKER_WS_URL: string
@description: "Solace WebSocket URL for SAM/n8n"
@default: "ws://solace-pubsub:8008"

SOLACE_VPN: string
@default: "discovery_tools_mesh"

SOLACE_USERNAME: string
@default: "admin"

SOLACE_PASSWORD: string
@sensitive: true
@required: true
@description: "Solace broker password (not used when mTLS-only)"

SOLACE_TLS_ENABLED: boolean
@default: true

SOLACE_CLIENT_CERT_PATH: string
@default: "/opt/mesh_secrets/certs/node_client.crt"

SOLACE_CLIENT_KEY_PATH: string
@default: "/opt/mesh_secrets/certs/node_client.key"

# --- Teleport (JIT access) ---
@env-spec: TELEPORT
TELEPORT_PROXY: string
@description: "Teleport proxy address (host or service name)"
@default: "teleport"

TELEPORT_AUTH_SERVER: string
@default: "teleport:3025"

TELEPORT_API_TOKEN: string
@sensitive: true
@required: true
@description: "Teleport API token for JIT / access request approval"

TELEPORT_JIT_REQUEST_URL: string
@description: "Custom JIT request endpoint (n8n calls this)"
@default: "https://teleport/api/v1/jit/request"

# --- Admin (single admin identity; store in Vault) ---
@env-spec: ADMIN
# KEYCLOAK_ADMIN / KEYCLOAK_ADMIN_PASSWORD are in IAM section; admin_ssh_public_key is the same admin's SSH public key for Gitea/Teleport/etc.
admin_ssh_public_key: string
@description: "SSH public key for admin user (e.g. kbolsen); used for Git and service admin access"
@sensitive: false
@required: false

admin_mfa_email: string
@description: "Email for admin MFA (OTP, recovery, or identity binding); e.g. kenneth.olsen.atm@gmail.com"
@default: "kenneth.olsen.atm@gmail.com"
@sensitive: false
@required: false

# --- Vault (secrets) ---
@env-spec: VAULT
VAULT_ADDR: string
@default: "http://vault:8200"

VAULT_TOKEN: string
@sensitive: true
@required: true

VAULT_SECRET_PATH: string
@default: "secret/devsecops"

# --- 1-bit LLM / BitNet (optional for SAM and n8n agents) ---
@env-spec: LLM_SERVICE
LLM_SERVICE_ENDPOINT: string
@description: "Local 1-bit LLM or BitNet endpoint (optional)"
@default: ""

LLM_SERVICE_API_KEY: string
@sensitive: true
@required: false

LLM_SERVICE_PLANNING_MODEL_NAME: string
@default: ""

LLM_SERVICE_GENERAL_MODEL_NAME: string
@default: ""

# --- Security & Compliance ---
@env-spec: SECURITY_COMPLIANCE
SECURITY_COMPLIANCE: string
@default: "CMMC_L2"
@validation: "CMMC_L2, STIG, PQC_READY"

PQC_KEM_SEED: string
@sensitive: true
@required: false
@description: "64-byte seed for ML-KEM post-quantum key encapsulation"

CMMC_LEVEL: string
@default: "Level 2"

# --- Network (100.64.0.0/10) ---
@env-spec: NETWORK
TOOLING_GITEA_CIDR: string
@default: "100.64.1.0/24"

TOOLING_N8N_CIDR: string
@default: "100.64.2.0/24"

TOOLING_ZAMMAD_CIDR: string
@default: "100.64.3.0/24"

MSG_BACKBONE_CIDR: string
@default: "100.64.10.0/24"

IAM_CIDR: string
@default: "100.64.20.0/24"

AGENT_MESH_CIDR: string
@default: "100.64.30.0/24"

# --- Discovery / BOM (optional) ---
@env-spec: DISCOVERY_ORCHESTRATION
DISCOVERY_NETWORK_SUBNET: string
@default: "100.64.10.0/24"

DISCOVERY_ORCHESTRATOR_ENABLED: boolean
@default: true

N8N_WEBHOOK_DISCOVERY_URL: string
@default: "http://n8n:5678/webhook/discovery-events"

# --- Integration (optional vendor) ---
VENDOR_API_KEY: string
@sensitive: true
@required: false
